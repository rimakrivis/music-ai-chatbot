# ============================================================
# Music AI Chatbot — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to GitHub.
# ============================================================

# --- OpenAI ---
# Get from: https://platform.openai.com/api-keys
# Used for: GPT-4o (agent), text-embedding-3-small (ChromaDB)
OPENAI_API_KEY=

# --- Spotify Web API ---
# Get from: https://developer.spotify.com/dashboard
# Used for: get_artist_info tool (monthly listeners, top tracks, genres)
# No user login needed — client credentials flow only
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- AssemblyAI ---
# Get from: https://www.assemblyai.com/dashboard
# Used for: audio transcription fallback when YouTube captions are disabled
ASSEMBLYAI_API_KEY=

# --- LangSmith (tracing + evaluation) ---
# Get from: https://smith.langchain.com/settings
# Used for: automatic agent tracing, evaluation dataset
LANGCHAIN_API_KEY=
LANGSMITH_API_KEY=       # same value as LANGCHAIN_API_KEY — both needed
LANGCHAIN_TRACING_V2=true
LANGSMITH_TRACING=true
LANGCHAIN_PROJECT=music-ai-chatbot

# --- Environment ---
# "local"      → ChromaDB uses PersistentClient (saves to ./chroma_db on disk)
# "production" → ChromaDB uses EphemeralClient (in-memory, resets on restart)
# Set to "production" on Railway
ENVIRONMENT=local
