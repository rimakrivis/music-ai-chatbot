# ============================================================
# Music AI Chatbot — Frontend Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEXT_PUBLIC_ prefix makes variables available in the browser.
# NEVER commit your .env.local file to GitHub.
# ============================================================

# URL of your FastAPI backend.
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production (replace with your actual Railway URL after deploying):
# NEXT_PUBLIC_API_URL=https://your-app-name.railway.app
